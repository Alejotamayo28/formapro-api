{
  "entryFile": "src/server.ts",
  "noImplicitAdditionalProperties": "throw-on-extras",
  "controllerPathGlobs": ["src/controllers/**/*.ts"],
  "spec": {
    "outputDirectory": "docs",
    "specVersion": 3,
    "basePath": "/",
    "securityDefinitions": {},
    "spec": {
      "info": {
        "title": "FormaPro Payments Dashboard API",
        "version": "1.0.0",
        "description": "API de solo lectura para consultar pagos, KPIs, gráficos y exportación CSV desde Supabase operations.payments."
      }
    }
  },
  "routes": {
    "routesDir": "src/routes",
    "middleware": "express"
  }
}
