{
	"openapi": "3.0.0",
	"components": {
		"examples": {},
		"headers": {},
		"parameters": {},
		"requestBodies": {},
		"responses": {},
		"schemas": {
			"HealthResponse": {
				"properties": {
					"ok": {
						"type": "boolean"
					}
				},
				"required": [
					"ok"
				],
				"type": "object",
				"additionalProperties": false
			},
			"PaymentCurrency": {
				"type": "string",
				"enum": [
					"cop",
					"usd"
				]
			},
			"PaymentsResponse": {
				"properties": {
					"pago_id": {
						"type": "string"
					},
					"email": {
						"type": "string"
					},
					"nombre": {
						"type": "string",
						"nullable": true
					},
					"curso": {
						"type": "string"
					},
					"importe": {
						"type": "number",
						"format": "double"
					},
					"moneda": {
						"$ref": "#/components/schemas/PaymentCurrency"
					},
					"fecha": {
						"type": "string"
					},
					"refunded_at": {
						"type": "string",
						"nullable": true
					}
				},
				"required": [
					"pago_id",
					"email",
					"nombre",
					"curso",
					"importe",
					"moneda",
					"fecha",
					"refunded_at"
				],
				"type": "object",
				"additionalProperties": false
			},
			"PaymentsWithPagesResponse": {
				"properties": {
					"payments": {
						"items": {
							"$ref": "#/components/schemas/PaymentsResponse"
						},
						"type": "array"
					},
					"number_of_pages": {
						"type": "number",
						"format": "double"
					}
				},
				"required": [
					"payments",
					"number_of_pages"
				],
				"type": "object",
				"additionalProperties": false
			},
			"PaymentStatus": {
				"type": "string",
				"enum": [
					"completed",
					"refunded"
				]
			},
			"PaymentSortBy": {
				"type": "string",
				"enum": [
					"id_pago",
					"email",
					"nombre",
					"curso",
					"importe",
					"moneda",
					"estado",
					"fecha",
					"refunded_at"
				]
			},
			"PaymentSortOrder": {
				"type": "string",
				"enum": [
					"ASC",
					"DESC"
				]
			},
			"MoneyMetric": {
				"properties": {
					"currency": {
						"$ref": "#/components/schemas/PaymentCurrency"
					},
					"amount": {
						"type": "number",
						"format": "double"
					}
				},
				"required": [
					"currency",
					"amount"
				],
				"type": "object",
				"additionalProperties": false
			},
			"PaymentsSummaryResponse": {
				"properties": {
					"total_payments": {
						"type": "number",
						"format": "double"
					},
					"total_refunds": {
						"type": "number",
						"format": "double"
					},
					"completed_revenue_by_currency": {
						"items": {
							"$ref": "#/components/schemas/MoneyMetric"
						},
						"type": "array"
					},
					"average_ticket_by_currency": {
						"items": {
							"$ref": "#/components/schemas/MoneyMetric"
						},
						"type": "array"
					}
				},
				"required": [
					"total_payments",
					"total_refunds",
					"completed_revenue_by_currency",
					"average_ticket_by_currency"
				],
				"type": "object",
				"additionalProperties": false
			}
		},
		"securitySchemes": {}
	},
	"info": {
		"title": "basic-api",
		"version": "1.0.0",
		"description": "Backend API TypeScript + TSOA para el dashboard de pagos FormaPro.",
		"license": {
			"name": "MIT"
		},
		"contact": {
			"name": "Alejandro Vergara Tamayo"
		}
	},
	"paths": {
		"/health": {
			"get": {
				"operationId": "GetHealth",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/HealthResponse"
								}
							}
						}
					}
				},
				"tags": [
					"Health"
				],
				"security": [],
				"parameters": []
			}
		},
		"/payments": {
			"get": {
				"operationId": "GetPayments",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/PaymentsWithPagesResponse"
								}
							}
						}
					}
				},
				"tags": [
					"Payments"
				],
				"security": [],
				"parameters": [
					{
						"in": "query",
						"name": "status",
						"required": false,
						"schema": {
							"$ref": "#/components/schemas/PaymentStatus"
						}
					},
					{
						"in": "query",
						"name": "currency",
						"required": false,
						"schema": {
							"$ref": "#/components/schemas/PaymentCurrency"
						}
					},
					{
						"in": "query",
						"name": "course",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"in": "query",
						"name": "name",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"in": "query",
						"name": "email",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"in": "query",
						"name": "sortBy",
						"required": false,
						"schema": {
							"$ref": "#/components/schemas/PaymentSortBy"
						}
					},
					{
						"in": "query",
						"name": "sortOrder",
						"required": false,
						"schema": {
							"$ref": "#/components/schemas/PaymentSortOrder"
						}
					},
					{
						"in": "query",
						"name": "limit",
						"required": false,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"in": "query",
						"name": "offset",
						"required": false,
						"schema": {
							"format": "double",
							"type": "number"
						}
					}
				]
			}
		},
		"/payments/summary": {
			"get": {
				"operationId": "GetPaymentsSummary",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/PaymentsSummaryResponse"
								}
							}
						}
					}
				},
				"tags": [
					"Payments"
				],
				"security": [],
				"parameters": [
					{
						"in": "query",
						"name": "status",
						"required": false,
						"schema": {
							"$ref": "#/components/schemas/PaymentStatus"
						}
					},
					{
						"in": "query",
						"name": "currency",
						"required": false,
						"schema": {
							"$ref": "#/components/schemas/PaymentCurrency"
						}
					},
					{
						"in": "query",
						"name": "course",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"in": "query",
						"name": "name",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"in": "query",
						"name": "email",
						"required": false,
						"schema": {
							"type": "string"
						}
					}
				]
			}
		},
		"/payments/export.csv": {
			"get": {
				"operationId": "ExportPaymentsCsv",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"text/csv": {
								"schema": {
									"type": "string",
									"format": "byte"
								}
							}
						}
					}
				},
				"tags": [
					"Payments"
				],
				"security": [],
				"parameters": [
					{
						"in": "query",
						"name": "status",
						"required": false,
						"schema": {
							"$ref": "#/components/schemas/PaymentStatus"
						}
					},
					{
						"in": "query",
						"name": "currency",
						"required": false,
						"schema": {
							"$ref": "#/components/schemas/PaymentCurrency"
						}
					},
					{
						"in": "query",
						"name": "course",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"in": "query",
						"name": "name",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"in": "query",
						"name": "email",
						"required": false,
						"schema": {
							"type": "string"
						}
					}
				]
			}
		}
	},
	"servers": [
		{
			"url": "http://localhost:3000",
			"description": "Local Environment"
		},
		{
			"url": "https://api-logali.alejotamayo.com",
			"description": "Production Environment"
		}
	]
}